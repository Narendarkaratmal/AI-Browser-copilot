{
  "manifest_version": 3,
  "name": "AI Browser Copilot",
  "version": "0.1.0",
  "description": "Summarize, explain, hint, and improve text from the current page.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*", "https://*.onrender.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Browser Copilot"
  },
  "background": {
    "service_worker": "background.js"
  }
}
